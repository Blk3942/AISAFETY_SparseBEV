{
  "description": "FUSA 检测评测加权：GT 权重=class_weights×ego_distance_bins×attribute_weights，用于加权 recall 分母 npos 与 TP 误差加权平均；precision 仍按官方为 TP/(TP+FP)。跨类 mAP/TP 再用 class_weights 聚合；nds 段可改 mean_ap_weight 与各 TP 分项倍率。",
  "class_weights": {
    "car": 1.0,
    "truck": 1.0,
    "bus": 1.0,
    "trailer": 1.0,
    "construction_vehicle": 1.0,
    "pedestrian": 2.0,
    "motorcycle": 1.2,
    "bicycle": 1.2,
    "traffic_cone": 1.0,
    "barrier": 1.0
  },
  "ego_distance_bins": [
    { "up_to_m": 10.0, "weight": 1.5 },
    { "up_to_m": 30.0, "weight": 1.0 },
    { "up_to_m": null, "weight": 0.7 }
  ],
  "attribute_weights": {
    "default": 1.0,
    "per_class": {
      "pedestrian": {
        "pedestrian.moving": 1.3,
        "pedestrian.standing": 1.0,
        "pedestrian.sitting_lying_down": 1.0,
        "_empty": 1.0,
        "_default": 1.0
      },
      "car": {
        "vehicle.moving": 1.15,
        "vehicle.parked": 0.9,
        "vehicle.stopped": 1.0,
        "_empty": 1.0,
        "_default": 1.0
      }
    }
  },
  "nds": {
    "mean_ap_weight": 5,
    "tp_metric_multipliers": {
      "trans_err": 1.0,
      "scale_err": 1.0,
      "orient_err": 1.0,
      "vel_err": 1.0,
      "attr_err": 1.0
    }
  }
}
